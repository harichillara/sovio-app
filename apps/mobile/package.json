{
  "name": "@sovio/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "analyze": "cross-env EXPO_ATLAS=true expo export --platform all --dump-sourcemap",
    "analyze:open": "expo-atlas",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "submit:prod": "eas submit --profile production",
    "update": "eas update --channel production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@sentry/react-native": "^6.10.0",
    "@sovio/core": "workspace:*",
    "@sovio/tokens": "workspace:*",
    "@sovio/ui": "workspace:*",
    "@tanstack/react-query": "^5.99.1",
    "expo": "~52.0.49",
    "expo-apple-authentication": "~7.1.3",
    "expo-auth-session": "~6.0.3",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-device": "~7.0.3",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.10",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-updates": "~0.27.5",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "4.4.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/node": "^25.6.0",
    "@types/react": "~18.3.28",
    "cross-env": "^10.1.0",
    "eas-cli": "^10.2.4",
    "expo-atlas": "^0.4.3",
    "typescript": "^5.9.3"
  }
}
