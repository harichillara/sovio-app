{
  "name": "@sovio/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "analyze": "cross-env EXPO_ATLAS=true expo export --platform all --dump-sourcemap",
    "analyze:open": "expo-atlas",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "submit:prod": "eas submit --profile production",
    "update": "eas update --channel production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@sentry/react-native": "^5.24.0",
    "@sovio/core": "workspace:*",
    "@sovio/tokens": "workspace:*",
    "@sovio/ui": "workspace:*",
    "@tanstack/react-query": "^5.99.1",
    "expo": "~51.0.0",
    "expo-apple-authentication": "~6.4.0",
    "expo-auth-session": "~5.5.0",
    "expo-constants": "~16.0.0",
    "expo-crypto": "~13.0.0",
    "expo-device": "~6.0.0",
    "expo-linking": "~6.3.0",
    "expo-location": "~17.0.0",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.1",
    "expo-updates": "~0.25.0",
    "expo-web-browser": "~13.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.19.13",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.0",
    "cross-env": "^7.0.3",
    "eas-cli": "^10.2.4",
    "expo-atlas": "^0.3.0",
    "typescript": "^5.4.0"
  }
}
