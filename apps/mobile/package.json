{
  "name": "@sovio/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "analyze": "cross-env EXPO_ATLAS=true expo export --platform all --dump-sourcemap",
    "analyze:open": "expo-atlas",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "submit:prod": "eas submit --profile production",
    "update": "eas update --channel production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@sentry/react-native": "^8.9.2",
    "@sovio/core": "workspace:*",
    "@sovio/tokens": "workspace:*",
    "@sovio/ui": "workspace:*",
    "@tanstack/react-query": "^5.99.1",
    "expo": "~55.0.17",
    "expo-apple-authentication": "~55.0.13",
    "expo-auth-session": "~55.0.15",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-device": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-location": "55.1.8",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "cross-env": "^10.1.0",
    "eas-cli": "^18.8.1",
    "expo-atlas": "^0.4.3",
    "typescript": "^5.9.3"
  }
}
