{
  "name": "@sovio/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "analyze": "cross-env EXPO_ATLAS=true expo export --platform all --dump-sourcemap",
    "analyze:open": "expo-atlas",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview",
    "build:prod": "eas build --profile production",
    "submit:prod": "eas submit --profile production",
    "update": "eas update --channel production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@sentry/react-native": "^6.14.0",
    "@sovio/core": "workspace:*",
    "@sovio/tokens": "workspace:*",
    "@sovio/ui": "workspace:*",
    "@tanstack/react-query": "^5.99.1",
    "expo": "~53.0.27",
    "expo-apple-authentication": "~7.2.4",
    "expo-auth-session": "~6.2.1",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-device": "~7.1.4",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.28.18",
    "expo-web-browser": "~14.2.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "4.11.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/node": "^25.6.0",
    "@types/react": "~19.0.14",
    "cross-env": "^10.1.0",
    "eas-cli": "^10.2.4",
    "expo-atlas": "^0.4.3",
    "typescript": "^5.8.3"
  }
}
