# =============================================================================
# Sovio env vars
# =============================================================================
# Copy to .env (root) and fill in values. Supabase edge-function secrets are
# NOT loaded from this file in production — set them with `supabase secrets
# set KEY=value`. They're listed here as the canonical inventory of every var
# a fresh environment needs.
# =============================================================================


# -----------------------------------------------------------------------------
# Mobile (Expo) — EXPO_PUBLIC_* are embedded in the client bundle.
# Safe to ship (anon key is protected by Postgres RLS).
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Web (Next.js) — NEXT_PUBLIC_* are embedded in the client bundle.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Next.js server-only (waitlist form POST target — marketing integration).
WAITLIST_WEBHOOK_URL=


# =============================================================================
# Supabase Edge Functions
# =============================================================================
# Set via: `supabase secrets set GEMINI_API_KEY=...`
# List live secrets with: `supabase secrets list`
# For local `supabase functions serve`, put these in supabase/.env.local
# =============================================================================

# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by the Supabase
# runtime at invocation time. Do NOT set them manually in production. They're
# listed here so local `supabase functions serve` can mirror prod behavior.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM — Google Gemini (used by ai-generate for drafts, weekly insights, etc.)
GEMINI_API_KEY=

# Place discovery — used by intent-refresh / matchmaker to enrich suggestions.
GOOGLE_MAPS_API_KEY=
PREDICTHQ_API_TOKEN=

# Stripe webhook — used by billing-webhook to verify `Stripe-Signature`.
# Rotate this when you rotate the Stripe webhook endpoint secret.
# Until STRIPE_READY=true in billing.service.ts, the staged path ignores it.
STRIPE_WEBHOOK_SECRET=

# Stripe — set STRIPE_READY=true only when the go-live runbook is complete.
STRIPE_READY=false
STRIPE_SECRET_KEY=
