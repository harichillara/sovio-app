# Live-Supabase integration tests — required env vars.
#
# Copy to `.env` (which is gitignored) before running `pnpm test:integration`.
# These point at the SAME project you deploy to. The suite is fenced:
#   - Test users use email pattern rls-test-<uuid>@sovio.test
#   - All rows created are owned by those users
#   - Teardown deletes users + their cascaded rows after every run
# See `README.md` for full safety notes.

# The project URL (e.g. https://kfqjapikievrgmszrimw.supabase.co)
SUPABASE_URL=

# Anon key — used to create per-user sessions after we admin-create users.
SUPABASE_ANON_KEY=

# Service-role key — used ONLY for admin operations (create/delete users,
# seed rows the tests intentionally cannot create client-side). Keep this
# out of any client bundle.
SUPABASE_SERVICE_ROLE_KEY=
